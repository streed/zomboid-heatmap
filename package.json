{
  "name": "zomboid-heatmap",
  "version": "0.1.0",
  "description": "A heatmap of Project Zomboid server events, overlaid on the full game map. Standalone, iframe-embeddable, reads server logs (not a server mod).",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun build ./public/app.ts --outdir ./dist --target browser --minify",
    "start": "bun run build && bun run ./src/index.ts",
    "dev": "bun run build && bun --watch run ./src/index.ts",
    "test": "bun test"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/leaflet": "^1.9.12",
    "@types/leaflet.heat": "^0.2.4"
  }
}

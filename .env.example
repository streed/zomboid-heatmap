# ── zomboid-heatmap configuration ──────────────────────────────────────────
# Copy to `.env` and edit. Bun loads `.env` automatically.

# REQUIRED: absolute path to your server's Project Zomboid Logs directory.
# Typical locations:
#   Linux (dedicated)  /home/<user>/Zomboid/Logs
#   Linux (steamcmd)   ~/.local/share/Steam/.../Zomboid/Logs  (or server's Zomboid/Logs)
#   Windows            C:\Users\<user>\Zomboid\Logs
#   Game host panels   often under .cache/Logs
LOGS_DIR=/home/youruser/Zomboid/Logs

# Game build. Selects the default community map + projection (see src/builds.ts).
#   41 -> map.projectzomboid.com (isometric)   [verified default]
#   42 -> b42map.com (verify MAP_DESC, see README "Targeting Build 42")
BUILD=41

# ── Map tiles (proxied + cached from a community map) ───────────────────────
# Override these only to point at a different map or a self-hosted tileset.
# TILE_UPSTREAM=https://map.projectzomboid.com/
# MAP_DESC=SurvivalB417812L0          # the folder under <upstream>/maps/
# MAP_DESCRIPTOR=map.xml              # DZI descriptor filename in that folder
# PROJECTION=iso                      # iso (community map) | ortho (top-down render)
# WORLD_TILES_X=15300                 # ortho only: world width in tiles -> pixels/tile

# ── Behaviour ───────────────────────────────────────────────────────────────
# REFRESH_MINUTES=5                   # how often logs are re-scanned
# BIN_SIZE=10                         # heatmap grid bin size, in game tiles
# PORT=8080
# DATA_DIR=./data                     # tile cache + parse state live here

# Who may embed the iframe (CSP frame-ancestors). Examples:
#   *                          any site (default)
#   https://my-pz-dashboard.example   only that origin
# FRAME_ANCESTORS=*
